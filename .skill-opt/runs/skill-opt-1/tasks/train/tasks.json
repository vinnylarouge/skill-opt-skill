[
  {
    "id": "t001",
    "group": "config",
    "prompt": "A team has existing test cases with gold answers for their skill. Which `feedback_source` mode best leverages that? One word.",
    "check": {
      "type": "exact_lower",
      "value": "user-suite"
    }
  },
  {
    "id": "t002",
    "group": "config",
    "prompt": "What is the default value of `holdout_fraction`? Reply with just the number.",
    "check": {
      "type": "contains_any_lower",
      "patterns": [
        "0.3"
      ]
    }
  },
  {
    "id": "t003",
    "group": "config",
    "prompt": "What is the default `edit_budget`? Reply with just the JSON object.",
    "check": {
      "type": "contains_all_lower",
      "patterns": [
        "max_ops",
        "3",
        "max_words",
        "80"
      ]
    }
  },
  {
    "id": "t004",
    "group": "config",
    "prompt": "What is the default `minibatch_size`? Reply with just the number.",
    "check": {
      "type": "contains_any_lower",
      "patterns": [
        "6"
      ]
    }
  },
  {
    "id": "t006",
    "group": "config",
    "prompt": "List the four valid values for `feedback_source`. Comma-separated.",
    "check": {
      "type": "contains_all_lower",
      "patterns": [
        "proposed-ratified",
        "autonomous",
        "user-suite",
        "live"
      ]
    }
  },
  {
    "id": "t008",
    "group": "layout",
    "prompt": "Path to the source-of-truth ledger file inside the run dir?",
    "check": {
      "type": "contains_any_lower",
      "patterns": [
        "ledger.csv"
      ]
    }
  },
  {
    "id": "t009",
    "group": "layout",
    "prompt": "Which file holds rejected edits across iterations? Relative path inside the run dir.",
    "check": {
      "type": "contains_any_lower",
      "patterns": [
        "memory/rejected-edits.md",
        "rejected-edits.md"
      ]
    }
  },
  {
    "id": "t011",
    "group": "layout",
    "prompt": "After an edit is ACCEPTED at iter K, the candidate is copied into the skill/ directory. Name BOTH files (relative paths inside the run dir) that get written.",
    "check": {
      "type": "contains_all_lower",
      "patterns": [
        "v",
        "current.md"
      ]
    }
  },
  {
    "id": "t012",
    "group": "layout",
    "prompt": "What are the 7 columns of ledger.csv in order? Comma-separated, lowercase, exact names.",
    "check": {
      "type": "regex_all_lower",
      "patterns": [
        "\\biter\\b",
        "\\bkind\\b",
        "\\bversion\\b",
        "\\bsplit\\b",
        "\\bmean_score\\b",
        "\\bn\\b",
        "\\bdecision\\b"
      ]
    }
  },
  {
    "id": "t013",
    "group": "phases",
    "prompt": "List the phases of one iteration of the inner loop in order. Comma-separated, lowercased.",
    "check": {
      "type": "contains_all_lower",
      "patterns": [
        "rollout",
        "score",
        "reflect",
        "edit",
        "gate",
        "memory"
      ]
    }
  },
  {
    "id": "t014",
    "group": "phases",
    "prompt": "After Edit produces a candidate, is the skill file (skill/current.md) updated immediately? Y or N.",
    "check": {
      "type": "starts_with_word_lower",
      "patterns": [
        "n",
        "no"
      ]
    }
  },
  {
    "id": "t015",
    "group": "phases",
    "prompt": "What is the EXACT context the dispatched Rollout subagent receives? Be precise.",
    "check": {
      "type": "contains_all_lower_and_not_any",
      "must": [
        "skill",
        "task"
      ],
      "must_not": [
        "memory",
        "ledger",
        "history",
        "past attempts",
        "rejected"
      ]
    }
  },
  {
    "id": "t017",
    "group": "discipline",
    "prompt": "Does an LLM make the accept/reject decision in skill-opt's gate? Answer Y or N, then one short sentence with the reason.",
    "check": {
      "type": "starts_no_and_contains_any",
      "patterns_after_no": [
        "ledger.py",
        "deterministic",
        "arithmetic",
        "ledger"
      ]
    }
  },
  {
    "id": "t019",
    "group": "discipline",
    "prompt": "An edit proposal contains 5 ops; the budget is max_ops=3. What is the correct action?",
    "check": {
      "type": "contains_any_lower",
      "patterns": [
        "trim",
        "fewer",
        "reduce",
        "reject",
        "ask for",
        "condense",
        "trimmed proposal"
      ]
    }
  },
  {
    "id": "t020",
    "group": "discipline",
    "prompt": "Before proposing a new edit, which file MUST the Optimizer hat read? Give the relative path.",
    "check": {
      "type": "contains_any_lower",
      "patterns": [
        "rejected-edits.md"
      ]
    }
  },
  {
    "id": "t022",
    "group": "discipline",
    "prompt": "True or false: the rollout subagent may read previous trajectories or rejected-edits memory.",
    "check": {
      "type": "starts_with_word_lower",
      "patterns": [
        "false",
        "f",
        "n",
        "no"
      ]
    }
  },
  {
    "id": "t025",
    "group": "gate",
    "prompt": "Write the shell command to compute the gate decision at iter 2 for candidate version `c2` with default margin. Assume the run dir is `.skill-opt/runs/foo-1/`.",
    "check": {
      "type": "contains_all_lower",
      "patterns": [
        "ledger.py",
        "gate",
        "c2",
        "--iter",
        "2"
      ]
    }
  },
  {
    "id": "t026",
    "group": "gate",
    "prompt": "The ledger.csv `kind` column has exactly two distinct row types. Name them.",
    "check": {
      "type": "contains_all_lower",
      "patterns": [
        "eval",
        "gate"
      ]
    }
  },
  {
    "id": "t027",
    "group": "gate",
    "prompt": "Why must the v0 holdout eval be recorded BEFORE the first gate call?",
    "check": {
      "type": "contains_any_lower",
      "patterns": [
        "baseline",
        "fail-open",
        "best",
        "no scores",
        "unconditional"
      ]
    }
  },
  {
    "id": "t028",
    "group": "resume",
    "prompt": "A run dir's ledger.csv shows rows up through `iter=2, kind=gate, decision=accept`. What does resume do next?",
    "check": {
      "type": "contains_any_lower",
      "patterns": [
        "iter 3",
        "iteration 3",
        "iter-03",
        "next iteration",
        "iter=3"
      ]
    }
  }
]