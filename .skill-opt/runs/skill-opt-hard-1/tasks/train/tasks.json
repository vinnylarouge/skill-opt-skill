[
  {
    "id": "h000",
    "group": "proc",
    "prompt": "Trace the SETUP phase for a fresh run with feedback_source=user-suite, holdout_fraction=0.4, and 25 user-provided tasks. List in order: (1) what files/dirs get created, (2) how many tasks end up in train vs holdout, (3) what gets recorded in ledger.csv. Be precise about paths and counts.",
    "check": {
      "type": "multi_criterion",
      "criteria": [
        {
          "check": {
            "type": "contains_all_lower",
            "patterns": [
              "config.yml",
              "tasks/train",
              "tasks/holdout",
              "skill/v0.md"
            ]
          },
          "weight": 2
        },
        {
          "check": {
            "type": "contains_all_lower",
            "patterns": [
              "15",
              "10"
            ]
          },
          "weight": 2
        },
        {
          "check": {
            "type": "contains_all_lower",
            "patterns": [
              "ledger",
              "v0",
              "holdout"
            ]
          },
          "weight": 1
        },
        {
          "check": {
            "type": "negation_aware",
            "must": [
              "suite.json"
            ],
            "must_not": [
              "rollout",
              "reflect",
              "edit"
            ],
            "presence_weight": 0.5,
            "absence_weight": 0.5
          },
          "weight": 1
        }
      ]
    }
  },
