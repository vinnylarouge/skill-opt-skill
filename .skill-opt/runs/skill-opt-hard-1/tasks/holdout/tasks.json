  {
    "id": "h014",
    "group": "config-gen",
    "prompt": "A user says: 'I want a conservative run \u2014 small edits, strict acceptance, patience for at least 5 bad rounds before stopping, and I want 40% of tasks held out for gating.' Generate ONLY the config keys that differ from defaults, as key: value pairs.",
    "check": {
      "type": "multi_criterion",
      "criteria": [
        {
          "check": {
            "type": "contains_any_lower",
            "patterns": [
              "early_stop_patience: 5",
              "early_stop_patience:5"
            ]
          },
          "weight": 2
        },
        {
          "check": {
            "type": "contains_any_lower",
            "patterns": [
              "holdout_fraction: 0.4",
              "holdout_fraction:0.4"
            ]
          },
          "weight": 2
        },
        {
          "check": {
            "type": "contains_any_lower",
            "patterns": [
              "gate_margin"
            ]
          },
          "weight": 1.5
        },
        {
          "check": {
            "type": "negation_aware",
            "must": [
              "gate_margin"
            ],
            "must_not": [
              "max_iterations: 12",
              "minibatch_size: 6"
            ],
            "presence_weight": 0.4,
            "absence_weight": 0.6
          },
          "weight": 1.5
        }
      ]
    }
  },
