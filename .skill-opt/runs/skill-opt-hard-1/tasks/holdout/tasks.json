          },
          "weight": 2
        },
        {
          "check": {
            "type": "contains_all_lower",
            "patterns": [
              "interactive"
            ]
          },
          "weight": 2
        },
        {
          "check": {
            "type": "contains_any_lower",
            "patterns": [
