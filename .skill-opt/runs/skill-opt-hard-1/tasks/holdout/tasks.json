[
  {
    "id": "h001",
    "group": "proc",
    "prompt": "Walk through iteration 1 of a run with parallelism=4, minibatch_size=6, edit_panel=2. For EACH phase (Rollout through Memory), state: how many subagents are dispatched, what files each writes, and what the main agent does after they finish. Be specific about file paths.",
    "check": {
      "type": "multi_criterion",
      "criteria": [
        {
          "check": {
            "type": "contains_all_lower",
            "patterns": [
              "rollout",
              "6",
              "trajectory"
            ]
          },
          "weight": 1
        },
        {
          "check": {
            "type": "contains_all_lower",
            "patterns": [
              "score",
              "score.json"
            ]
          },
          "weight": 1
        },
        {
          "check": {
            "type": "contains_all_lower",
            "patterns": [
              "candidate-01",
              "candidate-02"
            ]
          },
          "weight": 1.5
        },
        {
          "check": {
            "type": "contains_any_lower",
            "patterns": [
              "both candidates",
              "all 2 candidates",
              "gate runs holdout rollouts for all"
            ]
          },
          "weight": 1
        },
        {
          "check": {
            "type": "contains_all_lower",
            "patterns": [
              "memory",
              "rejected-edits"
            ]
          },
          "weight": 0.5
        }
      ]
    }
  },
  {
    "id": "h009",
    "group": "diag",
    "prompt": "Train scores across 4 iterations: [0.83, 0.50, 0.92, 0.83]. Holdout scores: [0.80, 0.80, 0.80, 0.80]. The optimizer keeps proposing edits but holdout never improves. What are TWO distinct possible root causes and what would you investigate for each?",
